// UniChat Enterprise - Prisma Schema
// Optimized for Multi-Tenancy

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  domain    String?  @unique
  logoUrl   String?
  plan      String   @default("starter")
  status    String   @default("active")
  maxUsers  Int      @default(500)
  branding  Json     @default("{}")
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  faculties          Faculty[]
  departments        Department[]
  cohorts            Cohort[]
  groups             Group[]
  messages           Message[]
  courses            Course[]
  teacherAssignments TeacherAssignment[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String?   @db.Uuid
  email        String?
  phone        String?
  studentId    String?
  staffId      String?
  fullName     String
  passwordHash String?
  role         String    @default("student")
  course       String?
  ntaLevel     String?
  departmentId String?   @db.Uuid
  avatarUrl    String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLogin    DateTime?

  tenant            Tenant?             @relation(fields: [tenantId], references: [id])
  department        Department?         @relation(fields: [departmentId], references: [id])
  groups            GroupMember[]
  messages          Message[]
  messageReceipts   MessageReceipt[]
  messageReactions  MessageReaction[]
  sessions          Session[]
  createdGroups     Group[]             @relation("GroupCreator")
  taughtAssignments TeacherAssignment[] @relation("TeacherAssignments")
  crAssignments     TeacherAssignment[] @relation("ClassReps")

  @@unique([tenantId, email])
  @@unique([tenantId, studentId])
  @@unique([tenantId, staffId])
  @@map("users")
}

model Faculty {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  departments Department[]

  @@map("faculties")
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  facultyId String   @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  createdAt DateTime @default(now())

  faculty   Faculty  @relation(fields: [facultyId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  cohorts   Cohort[]
  courses   Course[]
  teachers  User[]

  @@map("departments")
}

model Cohort {
  id           String   @id @default(uuid()) @db.Uuid
  departmentId String   @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@map("cohorts")
}

model Group {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  name              String
  description       String?
  type              String   @default("private")
  academicContextId String?  @db.Uuid
  // Tags a room as "the class chat for this course, at this NTA level" — set
  // when the room was auto-created from a TeacherAssignment. Null for DMs,
  // ad-hoc groups, and clubs, which aren't tied to a specific class.
  courseId          String?  @db.Uuid
  ntaLevel          String?
  avatarUrl         String?
  createdBy         String?  @db.Uuid
  createdAt         DateTime @default(now())

  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  creator    User?              @relation("GroupCreator", fields: [createdBy], references: [id])
  course     Course?            @relation(fields: [courseId], references: [id])
  members    GroupMember[]
  messages   Message[]
  assignment TeacherAssignment?

  @@map("groups")
}

model GroupMember {
  groupId    String    @db.Uuid
  userId     String    @db.Uuid
  role       String    @default("member")
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  // This member's own mute preference for this room — never touches whether
  // anyone else in the room gets notified, purely a per-recipient UI switch.
  muted      Boolean   @default(false)

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@map("group_members")
}

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  groupId   String   @db.Uuid
  senderId  String   @db.Uuid
  content   String   @db.Text
  type      String   @default("text")
  metadata  Json     @default("{}")
  isEdited  Boolean  @default(false)
  editedAt  DateTime?
  // Soft delete for "delete for everyone" — content is cleared and replaced
  // with a tombstone at the API layer, row stays (preserves ordering/replies
  // pointing at it) but every client renders it as removed.
  deletedAt DateTime?
  // Client-generated UUID, set once at compose time and resent unchanged on
  // every retry. Lets the server tell "this exact send, retried after a lost
  // response" apart from "a new message that happens to have similar
  // content" — the send endpoint upserts on this key instead of blindly
  // inserting, so a retried send can never create a duplicate message.
  clientMessageId String?  @unique
  replyToId String?  @db.Uuid
  createdAt DateTime @default(now())

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  group     Group             @relation(fields: [groupId], references: [id])
  sender    User              @relation(fields: [senderId], references: [id])
  replyTo   Message?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[]         @relation("MessageReplies")
  receipts  MessageReceipt[]
  reactions MessageReaction[]

  @@index([groupId])
  // The hot path for chat history is "this room's messages, in order" — the
  // single-column groupId index above forces an in-memory sort on createdAt
  // for every fetch. This compound index lets Postgres satisfy the whole
  // query (filter + order) directly from the index.
  @@index([groupId, createdAt])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("messages")
}

// Per-recipient, per-message delivery/read state — the persisted source of
// truth that was missing entirely before. Previously "delivered" was only
// ever a live Socket.IO signal (never survived a reload) and "read" was
// approximated on reload from a single room-level GroupMember.lastReadAt
// timestamp, which can't distinguish messages sent before vs. after that
// timestamp landed and has no per-message precision at all. One row per
// (message, recipient), created eagerly for every other room member at send
// time — simplest correct design at this app's scale (campus-sized rooms,
// not broadcast channels with thousands of members).
model MessageReceipt {
  messageId   String    @db.Uuid
  userId      String    @db.Uuid
  deliveredAt DateTime?
  readAt      DateTime?

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@id([messageId, userId])
  @@index([userId])
  @@map("message_receipts")
}

// One active reaction per user per message — tapping a different emoji
// replaces it, matching WhatsApp/Telegram rather than Discord's
// multi-reaction model, since that's the simpler and more familiar pattern
// for this product.
model MessageReaction {
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@id([messageId, userId])
  @@map("message_reactions")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  tokenHash  String
  deviceInfo Json?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

// A course belongs to a department; a teacher "teaches" it at a given NTA
// level via a TeacherAssignment, which is also where a Class Rep gets pinned.
model Course {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  departmentId String   @db.Uuid
  name         String
  createdAt    DateTime @default(now())

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  department  Department          @relation(fields: [departmentId], references: [id])
  assignments TeacherAssignment[]
  rooms       Group[]

  @@map("courses")
}

// One row per (teacher, course, NTA level, module) they're assigned to teach.
// crUserId is the student promoted to Class Rep for it — role promotion/
// demotion on the User itself is handled in application code, this row is
// the source of truth for which assignment granted it. groupId is the class
// chat room auto-created alongside the assignment (one room per module).
model TeacherAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  teacherId  String   @db.Uuid
  courseId   String   @db.Uuid
  ntaLevel   String
  moduleName String? // required at the app layer for new rows; nullable in the
                     // DB so this column could be added without a destructive
                     // reset on an install that already had assignment rows
  crUserId   String?  @db.Uuid
  groupId    String?  @db.Uuid @unique
  createdAt  DateTime @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id])
  teacher User   @relation("TeacherAssignments", fields: [teacherId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])
  cr      User?  @relation("ClassReps", fields: [crUserId], references: [id])
  group   Group? @relation(fields: [groupId], references: [id])

  @@unique([teacherId, courseId, ntaLevel, moduleName])
  @@map("teacher_assignments")
}
