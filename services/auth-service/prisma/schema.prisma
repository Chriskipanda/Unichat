// UniChat Enterprise - Prisma Schema
// Optimized for Multi-Tenancy

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  domain    String?  @unique
  logoUrl   String?
  plan      String   @default("starter")
  status    String   @default("active")
  maxUsers  Int      @default(500)
  branding  Json     @default("{}")
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  faculties          Faculty[]
  departments        Department[]
  cohorts            Cohort[]
  groups             Group[]
  messages           Message[]
  courses            Course[]
  teacherAssignments TeacherAssignment[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String?   @db.Uuid
  email        String?
  phone        String?
  studentId    String?
  staffId      String?
  fullName     String
  passwordHash String?
  role         String    @default("student")
  course       String?
  ntaLevel     String?
  departmentId String?   @db.Uuid
  avatarUrl    String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLogin    DateTime?

  tenant            Tenant?             @relation(fields: [tenantId], references: [id])
  department        Department?         @relation(fields: [departmentId], references: [id])
  groups            GroupMember[]
  messages          Message[]
  sessions          Session[]
  createdGroups     Group[]             @relation("GroupCreator")
  taughtAssignments TeacherAssignment[] @relation("TeacherAssignments")
  crAssignments     TeacherAssignment[] @relation("ClassReps")

  @@unique([tenantId, email])
  @@unique([tenantId, studentId])
  @@unique([tenantId, staffId])
  @@map("users")
}

model Faculty {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  departments Department[]

  @@map("faculties")
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  facultyId String   @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  createdAt DateTime @default(now())

  faculty   Faculty  @relation(fields: [facultyId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  cohorts   Cohort[]
  courses   Course[]
  teachers  User[]

  @@map("departments")
}

model Cohort {
  id           String   @id @default(uuid()) @db.Uuid
  departmentId String   @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@map("cohorts")
}

model Group {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  name              String
  description       String?
  type              String   @default("private")
  academicContextId String?  @db.Uuid
  createdBy         String?  @db.Uuid
  createdAt         DateTime @default(now())

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  creator  User?         @relation("GroupCreator", fields: [createdBy], references: [id])
  members  GroupMember[]
  messages Message[]

  @@map("groups")
}

model GroupMember {
  groupId    String    @db.Uuid
  userId     String    @db.Uuid
  role       String    @default("member")
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@map("group_members")
}

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  groupId   String   @db.Uuid
  senderId  String   @db.Uuid
  content   String   @db.Text
  type      String   @default("text")
  metadata  Json     @default("{}")
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  group  Group  @relation(fields: [groupId], references: [id])
  sender User   @relation(fields: [senderId], references: [id])

  @@index([groupId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("messages")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  tokenHash  String
  deviceInfo Json?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

// A course belongs to a department; a teacher "teaches" it at a given NTA
// level via a TeacherAssignment, which is also where a Class Rep gets pinned.
model Course {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  departmentId String   @db.Uuid
  name         String
  createdAt    DateTime @default(now())

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  department  Department          @relation(fields: [departmentId], references: [id])
  assignments TeacherAssignment[]

  @@map("courses")
}

// One row per (teacher, course, NTA level) they're assigned to teach. crUserId
// is the student promoted to Class Rep for that specific course+level — role
// promotion/demotion on the User itself is handled in application code, this
// row is the source of truth for which assignment granted it.
model TeacherAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  teacherId String   @db.Uuid
  courseId  String   @db.Uuid
  ntaLevel  String
  crUserId  String?  @db.Uuid
  createdAt DateTime @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id])
  teacher User   @relation("TeacherAssignments", fields: [teacherId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])
  cr      User?  @relation("ClassReps", fields: [crUserId], references: [id])

  @@unique([teacherId, courseId, ntaLevel])
  @@map("teacher_assignments")
}
